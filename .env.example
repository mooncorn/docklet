# Location to store application data
DOCKLET_DATA_DIR=./docklet-data

# Host path corresponding to DOCKLET_DATA_DIR, used for Docker bind mounts.
# Set this when running Docklet inside a container and the data directory path
# on the Docker host differs from its path inside the Docklet container
# (e.g. Docker Desktop on Mac).
# HOST_DATA_DIR=